{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "production": {
      "autoIncrement": false,
      "env": {
        "EXPO_PUBLIC_DOMAIN": "1v1spades.com"
      }
    },
    "staging": {
      "autoIncrement": false,
      "env": {
        "EXPO_PUBLIC_DOMAIN": "onev1-spades-staging.onrender.com"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6776721716"
      }
    }
  }
}
